{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Server-targeted package: no DOM lib. URLSearchParams and friends come
    // from @types/node globals (Node ≥ 24 ships them); an accidental
    // window/document reference must fail to typecheck.
    "lib": ["ES2023"],
    "types": ["node"],
    "noEmit": true
  },
  "include": ["src", "test"],
  // Type tests contain intentional type errors (toRaiseError); they are
  // checked by tstyche (see tsconfig.tstyche.json), not tsc.
  "exclude": ["test/**/*.tst.ts"]
}
