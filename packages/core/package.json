{
  "name": "paramour",
  "version": "0.3.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "description": "Type-safe routing companion for the Next.js App Router: validated route params and search params, typed path building, and explicit URL serialization.",
  "keywords": [
    "nextjs",
    "app-router",
    "typescript",
    "routing",
    "type-safe",
    "search-params",
    "route-params",
    "standard-schema"
  ],
  "author": "Jason Paff <jasonpaff@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JasonPaff/paramour.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/JasonPaff/paramour#readme",
  "bugs": {
    "url": "https://github.com/JasonPaff/paramour/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "arktype": "^2.2.3",
    "fast-check": "^4.8.0",
    "valibot": "^1.4.2",
    "zod": "^4.4.3"
  }
}
