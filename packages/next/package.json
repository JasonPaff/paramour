{
  "name": "@paramour-js/next",
  "version": "0.2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    },
    "./devtools-seam": {
      "types": "./dist/devtools-seam.d.ts"
    },
    "./pages": {
      "types": "./dist/pages.d.ts",
      "default": "./dist/pages.js"
    }
  },
  "sideEffects": false,
  "bin": {
    "paramour": "./bin/paramour.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "jiti": "^2.7.0",
    "magicast": "^0.3.5",
    "paramour": "workspace:*",
    "tinyglobby": "^0.2.15"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "happy-dom": "^15.11.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "description": "Next.js integration for paramour: withTypedRoutes, App and Pages Router hooks, PageProps glue, and the codegen CLI.",
  "author": "Jason Paff <jasonpaff@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JasonPaff/paramour.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/JasonPaff/paramour#readme",
  "bugs": {
    "url": "https://github.com/JasonPaff/paramour/issues"
  },
  "files": [
    "bin",
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
