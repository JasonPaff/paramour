{
  "name": "@paramour-js/next",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "bin": {
    "paramour": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "jiti": "^2.7.0",
    "paramour": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "happy-dom": "^15.11.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.3"
  },
  "description": "Next.js integration for paramour: withTypedRoutes, client hooks, PageProps glue, and the codegen CLI.",
  "author": "Jason Paff <jasonpaff@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JasonPaff/paramour.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/JasonPaff/paramour#readme",
  "bugs": {
    "url": "https://github.com/JasonPaff/paramour/issues"
  },
  "files": [
    "dist"
  ]
}
